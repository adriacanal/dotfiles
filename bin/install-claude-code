#!/bin/bash
#
# Standalone Claude Code installation script
# Can be run independently or as part of full dotfiles setup

set -e

# Colors
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

step() { echo ""; echo -e "${BLUE}➜${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1"; exit 1; }

echo ""
echo "Claude Code Installation"
echo "========================"
echo ""

# Install Claude Code
step "Installing Claude Code CLI"
if command -v claude &>/dev/null; then
    warn "Claude Code already installed"
else
    # Try Homebrew first (modern)
    if command -v brew &>/dev/null; then
        brew install --cask claude-code
    else
        # Fallback to curl installer
        warn "Homebrew not found, using curl installer"
        curl -fsSL https://claude.ai/install.sh | bash
    fi
fi
success "Claude Code installed"

# Check if running from dotfiles repo
DOTFILES_DIR="$HOME/.dotfiles"
if [ ! -d "$DOTFILES_DIR" ]; then
    # Try to detect if script is in a dotfiles directory
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [ -f "$SCRIPT_DIR/../config/claude/CLAUDE.md" ]; then
        DOTFILES_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
    fi
fi

# Claude configuration
if [ -d "$DOTFILES_DIR/config/claude" ]; then
    step "Setting up Claude Code configuration"
    mkdir -p ~/.claude/skills

    # Symlink configuration files
    ln -sf "$DOTFILES_DIR/config/claude/CLAUDE.md" ~/.claude/CLAUDE.md
    ln -sf "$DOTFILES_DIR/config/claude/laravel-php-guidelines.md" ~/.claude/laravel-php-guidelines.md
    ln -sf "$DOTFILES_DIR/config/claude/settings.json" ~/.claude/settings.json

    # Symlink custom skills if they exist
    if [ -d "$DOTFILES_DIR/config/claude/skills/convert-issue-to-discussion" ]; then
        ln -sf "$DOTFILES_DIR/config/claude/skills/convert-issue-to-discussion" ~/.claude/skills/convert-issue-to-discussion
    fi
    if [ -d "$DOTFILES_DIR/config/claude/skills/fix-github-issue" ]; then
        ln -sf "$DOTFILES_DIR/config/claude/skills/fix-github-issue" ~/.claude/skills/fix-github-issue
    fi
    if [ -d "$DOTFILES_DIR/config/claude/skills/ray-skill" ]; then
        ln -sf "$DOTFILES_DIR/config/claude/skills/ray-skill" ~/.claude/skills/ray-skill
    fi

    success "Claude Code configured"
else
    warn "Dotfiles directory not found, skipping configuration"
    echo "  To set up configuration later, clone dotfiles to ~/.dotfiles"
fi

# Agent Skills
step "Installing agent skills"

# Check if Node.js is available
if ! command -v npx &>/dev/null; then
    warn "Node.js/npx not found, skipping agent skills"
    echo "  Install Node.js to add community skills"
else
    npx -y skills add vercel-labs/agent-skills
    npx -y skills add anthropics/skills
    npx -y skills add expo/skills
    npx -y skills add vercel-labs/agent-browser
    npx -y skills add coreyhaines31/marketingskills
    npx -y skills add callstackincubator/agent-skills
    success "Agent skills installed"
fi

# Done
echo ""
success "Claude Code setup complete!"
echo ""
step "Next steps:"
if [ ! -d "$DOTFILES_DIR/config/claude" ]; then
    echo "  • Clone dotfiles for custom configuration:"
    echo "    git clone https://github.com/freekmurze/dotfiles.git ~/.dotfiles"
    echo "    ~/.dotfiles/bin/install-claude-code"
    echo ""
fi
echo "  • Start using: claude"
echo "  • Discover more skills: https://skills.sh"
echo ""
