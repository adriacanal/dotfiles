#!/bin/bash
#
# Health check for dotfiles installation

# Colors
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

check() { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }
fail() { echo -e "${RED}✗${NC} $1"; }
info() { echo -e "${BLUE}ℹ${NC} $1"; }

ERRORS=0
WARNINGS=0

echo ""
info "Dotfiles Health Check"
echo ""

# Check symlinks
info "Checking symlinks..."
for link in .zshrc .vimrc .vim .global-gitignore .mackup.cfg; do
    if [ -L ~/$link ]; then
        check "$link is symlinked"
    else
        fail "$link is not symlinked"
        ((ERRORS++))
    fi
done
echo ""

# Check modern tools
info "Checking modern tools..."
for tool in starship zoxide bat eza rg fd delta fnm fzf direnv; do
    if command -v $tool &>/dev/null; then
        check "$tool installed"
    else
        warn "$tool not installed"
        ((WARNINGS++))
    fi
done
echo ""

# Check version managers
info "Checking fnm..."
if command -v fnm &>/dev/null; then
    if fnm current &>/dev/null; then
        check "Node.js: $(fnm current)"
    else
        warn "Node.js not configured in fnm"
        ((WARNINGS++))
    fi
else
    fail "fnm not installed"
    ((ERRORS++))
fi
echo ""

# Check PHP
info "Checking PHP..."
if command -v php &>/dev/null; then
    check "PHP: $(php -v | head -n1 | cut -d' ' -f2)"
else
    fail "PHP not installed"
    ((ERRORS++))
fi
echo ""

# Check shell
info "Checking home..."
if [ "$SHELL" = "/bin/zsh" ]; then
    check "Default shell is zsh"
else
    warn "Default shell is not zsh (current: $SHELL)"
    ((WARNINGS++))
fi
echo ""

# Check Homebrew
info "Checking Homebrew..."
if command -v brew &>/dev/null; then
    check "Homebrew installed"

    # Check for outdated packages
    OUTDATED=$(brew outdated | wc -l | tr -d ' ')
    if [ "$OUTDATED" -gt 0 ]; then
        warn "$OUTDATED packages are outdated (run: bin/update)"
        ((WARNINGS++))
    else
        check "All packages up to date"
    fi
else
    fail "Homebrew not installed"
    ((ERRORS++))
fi
echo ""

# Check Composer
if command -v composer &>/dev/null; then
    check "Composer installed: $(composer --version 2>/dev/null | head -n1 | cut -d' ' -f3)"
else
    fail "Composer not installed"
    ((ERRORS++))
fi
echo ""

# Summary
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $ERRORS -eq 0 ] && [ $WARNINGS -eq 0 ]; then
    check "Everything looks good!"
    exit 0
elif [ $ERRORS -eq 0 ]; then
    warn "$WARNINGS warnings found"
    exit 0
else
    fail "$ERRORS errors and $WARNINGS warnings found"
    exit 1
fi
