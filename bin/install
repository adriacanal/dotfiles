#!/bin/bash
#
# Install dotfiles

set -e

# Colors
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

step() { echo ""; echo -e "${BLUE}➜${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1"; exit 1; }

echo ""
step "Install Dotfiles"
echo ""
warn "This will install/update your terminal setup"
echo ""
read -p "Continue? (y/n) " -n 1 -r
echo ""

if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo ""
    step "Cancelled"
    echo ""
    exit 0
fi

echo ""
sudo -v

# Start
touch ~/.hushlogin
step "Installing Oh My Zsh"
if [ ! -d ~/.oh-my-zsh ]; then
    rm -rf ~/.oh-my-zsh
    curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh | sh -s -- --unattended
fi
success "Oh My Zsh installed"

# Git configuration
step "Configuring Git"
ln -sf ~/.dotfiles/home/.global-gitignore ~/.global-gitignore
git config --global core.excludesfile ~/.global-gitignore
git config --global push.autoSetupRemote true
success "Git configured"

# Symlinks
step "Creating symlinks"
rm -f ~/.zshrc ~/.vimrc ~/.vim ~/.mackup.cfg
ln -sf ~/.dotfiles/home/.zshrc ~/.zshrc
ln -sf ~/.dotfiles/home/.vimrc ~/.vimrc
ln -sf ~/.dotfiles/home/.vim ~/.vim
ln -sf ~/.dotfiles/macos/.mackup.cfg ~/.mackup.cfg
success "Symlinks created"

# NPM setup
step "Configuring npm"
mkdir -p ~/.npm-packages
npm config set prefix ~/.npm-packages
success "npm configured"

# Homebrew
step "Installing Homebrew"
if ! command -v brew &>/dev/null; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> ~/.zprofile
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi
success "Homebrew installed"

# Install all packages from Brewfile
step "Installing packages from Brewfile"
brew bundle --file=~/.dotfiles/config/Brewfile
success "All packages installed"

# mise - version manager
step "Setting up mise"
mkdir -p ~/.config/mise
ln -sf ~/.dotfiles/config/.mise.toml ~/.config/mise/config.toml
eval "$(mise activate bash)"
mise use --global node@lts
mise use --global php@8.4
mise use --global ruby@latest
mise install
success "mise configured"


# Composer
step "Installing Composer"
if ! command -v composer &>/dev/null; then
    EXPECTED_CHECKSUM="$(curl -fsSL https://composer.github.io/installer.sig)"
    php -r "copy('https://getcomposer.org/installer', 'composer-setup.php');"
    ACTUAL_CHECKSUM="$(php -r "echo hash_file('sha384', 'composer-setup.php');")"
    if [ "$EXPECTED_CHECKSUM" != "$ACTUAL_CHECKSUM" ]; then
        rm composer-setup.php
        error "Composer checksum mismatch"
    fi
    php composer-setup.php --quiet
    sudo mkdir -p /usr/local/bin/
    sudo mv composer.phar /usr/local/bin/composer
    rm composer-setup.php
fi
success "Composer installed"

# PHP extensions
step "Installing PHP extensions"
pecl install imagick || true
pecl install memcached || true
pecl install xdebug || true
pecl install redis || true
success "PHP extensions installed"

# Global npm packages
step "Installing global npm packages"
npm install -g aicommits
npm install -g agent-browser
agent-browser install || true
success "npm packages installed"

# Global Composer packages
step "Installing global Composer packages"
composer global require laravel/envoy
composer global require spatie/phpunit-watcher
composer global require laravel/valet
valet install
success "Composer packages installed"

# MySQL
step "Starting MySQL"
brew services start mysql
success "MySQL started"

# Claude Code setup
bash ~/.dotfiles/bin/install-claude-code

# Done
echo ""
success "Installation complete!"
echo ""
step "Next steps:"
echo "  • Run health check: bin/doctor"
echo "  • Install Menlo Powerline font: config/fonts/Menlo-Powerline.otf"
echo "  • Import Solarized theme: config/iterm/*.itermcolors"
echo "  • Restore settings: mackup restore (if you have backups)"
echo "  • Customize aliases: ~/.dotfiles-custom/shell/.aliases"
echo ""
echo "Optional:"
echo "  • Discover more agent skills: https://skills.sh"
echo ""
